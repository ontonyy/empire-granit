{
  "name": "empire-granit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run validate:content && npm run generate:seo && vite build && vite build --ssr src/ssr/entry-server.tsx --outDir dist-ssr && node scripts/prerender.mjs",
